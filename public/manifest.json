    { "src": "/gunesos/icons/icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "/gunesos/icons/icon-256.png", "sizes": "256x256", "type": "image/png", "purpose": "any" },
    { "src": "/gunesos/icons/icon-384.png", "sizes": "384x384", "type": "image/png", "purpose": "any" },
    { "src": "/gunesos/icons/icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any" },
