      "url": "/gunesos/?app=sohbeto",
      "icons": [{ "src": "/gunesos/icons/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Yapay Akıl",
      "short_name": "Yapay Akıl",
